export default "# Simulation catalog source-of-truth.\n#\n# Each top-level key is one simulation family shown in the UI.\n#\n# `metadata.summaryStats`\n#   End-of-run summary cards.\n#\n# `metadata.liveStats`\n#   Top-right live telemetry rows.\n#   - `value` is the initial/fallback display value\n#   - `unit` is appended by the app\n#   - `live: true` means a CSV stream should provide updates\n#   - `live_key` can override which CSV column should be used\n#   - `from_video: true` means the final value should be pulled from the active\n#     video's sidecar metadata YAML\n#   - `video_key` can override which metadata key should be used\n#   - `scale_with_time: true` (when `live`) scales the final metadata value\n#     linearly by normalized playback time\n#\n# `parameters`\n#   Config-overlay controls and parameter-space metadata.\n\nplanetary:\n  label: Planetary\n  icon: '🌍'\n  placeholderImage: /assets/planet_example.webp\n  metadata:\n    distinctSimulations: 384\n    correctValues:\n      impactor_mass: 0.12\n      impactor_velocity: 14\n      impactor_angle: 43\n    summaryStats:\n      - id: runtime\n        value: '0.00'\n        unit: hours\n        from_video: true\n        video_key: wallclockSeconds\n      - id: similarityScore\n        value: 100/100\n      - id: carbonBurnt\n        value: '0.00'\n        unit: kgCO2e\n        from_video: true\n      - id: computeUsed\n        value: '0.0'\n        unit: smartphones\n        from_video: true\n      - id: memoryUsed\n        value: '0.0'\n        unit: GB\n        from_video: true\n      - id: particlesUpdated\n        value: '0'\n        label: Particle updates\n        from_video: true\n    liveStats:\n      - id: impactor_mass\n        value: '0.10'\n        unit: M⊕\n        live: false\n      - id: impactor_velocity\n        value: '12.0'\n        unit: km/s\n        live: false\n      - id: impactor_angle\n        value: '45'\n        unit: °\n        live: false\n      - id: time\n        value: 0.0\n        unit: hours\n        live: true\n      - id: temperature\n        value: 0.0\n        unit: K\n        live: true\n      - id: Earth mass\n        value: 1.0\n        unit: M⊕\n        live: true\n      - id: particlesUpdated\n        value: '0'\n        label: Particle updates\n        live: true\n        from_video: true\n        scale_with_time: true\n        integer: true\n  parameters:\n    impactor_mass:\n      label: Impactor Mass\n      unit: M⊕\n      min: 0.01\n      max: 10\n      step: 0.01\n      default: 0.1\n    impactor_velocity:\n      label: Impactor Velocity\n      unit: km/s\n      min: 1\n      max: 50\n      step: 0.5\n      default: 12\n    impactor_angle:\n      label: Impactor Angle\n      unit: °\n      min: 0\n      max: 90\n      step: 1\n      default: 45\n\ngalaxy:\n  label: Galaxy\n  icon: '🌀'\n  placeholderImage: /assets/galaxy_example.webp\n  metadata:\n    distinctSimulations: 2048\n    correctValues:\n      star_formation_rate: 2.4\n      black_hole_mass: 4.3\n      diskiness: 0.78\n      stellar_mass: 5.1\n    summaryStats:\n      - id: runtime\n        value: '0.00'\n        unit: hours\n        from_video: true\n        video_key: wallclockSeconds\n      - id: similarityScore\n        value: 100/100\n      - id: carbonBurnt\n        value: '0.00'\n        unit: kgCO2e\n        from_video: true\n      - id: computeUsed\n        value: '0.0'\n        unit: smartphones\n        from_video: true\n      - id: memoryUsed\n        value: '0.0'\n        unit: GB\n        from_video: true\n      - id: particlesUpdated\n        value: '0'\n        label: Particle updates\n        from_video: true\n    liveStats:\n      - id: star_formation_rate\n        value: '3.0'\n        unit: M☉/yr\n        live: true\n      - id: black_hole_mass\n        value: '4.0'\n        unit: ×10⁶ M☉\n        live: true\n      - id: stellar_mass\n        value: '5.0'\n        unit: ×10¹⁰ M☉\n        live: true\n      - id: size\n        value: 0.0\n        unit: kpc\n        live: true\n      - id: age\n        value: 0.0\n        unit: Gyr\n        live: true\n      - id: particlesUpdated\n        value: '0'\n        label: Particle updates\n        live: true\n        from_video: true\n        scale_with_time: true\n        integer: true\n  parameters:\n    star_formation_rate:\n      label: Star Formation Rate\n      unit: M☉/yr\n      min: 0.1\n      max: 100\n      step: 0.1\n      default: 3\n    black_hole_mass:\n      label: Black Hole Mass\n      unit: '×10⁶ M☉'\n      min: 0.1\n      max: 1000\n      step: 0.1\n      default: 4\n    diskiness:\n      label: Diskiness\n      unit: ''\n      min: 0\n      max: 1\n      step: 0.01\n      default: 0.7\n    stellar_mass:\n      label: Stellar Mass\n      unit: '×10¹⁰ M☉'\n      min: 0.01\n      max: 50\n      step: 0.01\n      default: 5\n\ncosmos:\n  label: Cosmos\n  icon: '✨'\n  placeholderImage: /assets/cosmos_example.webp\n  metadata:\n    distinctSimulations: 8192\n    correctValues:\n      dark_matter_density: 0.27\n      baryon_density: 0.049\n      feedback_strength: 1.1\n      clustering: 0.81\n    summaryStats:\n      - id: runtime\n        value: '0.00'\n        unit: hours\n        from_video: true\n        video_key: wallclockSeconds\n      - id: similarityScore\n        value: 100/100\n      - id: carbonBurnt\n        value: '0.00'\n        unit: kgCO2e\n        from_video: true\n      - id: computeUsed\n        value: '0.0'\n        unit: smartphones\n        from_video: true\n      - id: memoryUsed\n        value: '0.0'\n        unit: GB\n        from_video: true\n      - id: particlesUpdated\n        value: '0'\n        label: Particle updates\n        from_video: true\n    liveStats:\n      - id: dark_matter_density\n        value: '0.27'\n        unit: Ωdm\n        live: false\n      - id: baryon_density\n        value: '0.049'\n        unit: Ωb\n        live: false\n      - id: clustering\n        value: '0.81'\n        unit: σ₈\n        live: false\n      - id: age\n        value: 0.0\n        unit: Gyr\n        live: true\n      - id: redshift\n        value: 0.0\n        unit: ''\n        live: true\n      - id: particlesUpdated\n        value: '0'\n        label: Particle updates\n        live: true\n        from_video: true\n        scale_with_time: true\n        integer: true\n  parameters:\n    dark_matter_density:\n      label: Dark Matter Density\n      unit: Ωdm\n      min: 0.05\n      max: 0.8\n      step: 0.01\n      default: 0.27\n    baryon_density:\n      label: Baryon Density\n      unit: Ωb\n      min: 0.01\n      max: 0.15\n      step: 0.001\n      default: 0.049\n    feedback_strength:\n      label: Feedback Strength\n      unit: ''\n      min: 0\n      max: 5\n      step: 0.1\n      default: 1\n    clustering:\n      label: Clustering\n      unit: σ₈\n      min: 0.4\n      max: 1.2\n      step: 0.01\n      default: 0.81\n"